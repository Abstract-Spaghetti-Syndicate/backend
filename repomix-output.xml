                            <input id="manual-printer-name" type="text" placeholder="напр. Voron, Ender, My Octo" class="w-full bg-gray-900 border border-gray-700 rounded px-3 py-2 text-sm focus:outline-none focus:border-blue-500 text-white">
                        </div>
