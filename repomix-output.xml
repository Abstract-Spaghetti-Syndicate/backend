                    <div id="sessions-list" class="space-y-2 max-h-44 overflow-y-auto pr-1"></div>
                </div>
            </div>
        </div>

       <!-- Склад інвентарю (Вкладки) -->
        <div class="bg-gray-800 p-6 rounded-lg shadow-lg border border-gray-700 mt-6 relative">
